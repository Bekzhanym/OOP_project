#!/usr/bin/env bash
# Интеграционный прогон консоли + проверка persistence (Java serialization).
# Сохраняет ваш university-state.ser во временный файл и восстанавливает после выхода.

set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
SER="$ROOT/data/university-state.ser"
TMP_SER="$ROOT/data/university-state.ser.integration-test-backup-$$"

restore_state() {
  rm -f "$SER"
  if [[ -f "$TMP_SER" ]]; then
    mv "$TMP_SER" "$SER"
    echo "[integration-test] Восстановлен прежний data/university-state.ser"
  else
    echo "[integration-test] Файла сохранения не было — каталог без university-state.ser"
  fi
}
trap restore_state EXIT

if [[ -f "$SER" ]]; then
  cp "$SER" "$TMP_SER"
  echo "[integration-test] Резервная копия: $TMP_SER"
fi}
  
rm -f "$SER"

echo "[integration-test] Компиляция..."
find src -name "*.java" -print0 | xargs -0 javac -d out -encoding UTF-8

JAVA_RUN=(java -cp out kbtu_oop_project.console.ConsoleDemo)

echo "[integration-test] Фаза A — создаём пользователей, курс, оценки, новость, сохранение..."
PHASE_A_OUTPUT="$(mktemp)"
run_phase_a() {
  cat <<'INPUT'
n
2
4
admin@kbtu.kz
adm
Admin
Test
adm123
0
2
2
teach@kbtu.kz

t1
Tea
Cher
tea123
15
CS
0
2
1
stud@kbtu.kz

s1
Stu
Dent
stu123

0
2
5
mgr@kbtu.kz
m1
Man
Ger
mgr123
0
1
mgr@kbtu.kz

mgr123
7
INT101
Integration Course
6
CS
2
1
1
2
9
11
3
teach@kbtu.kz
INT101
8
2
Persistence line from integration test
0
1
stud@kbtu.kz
stu123
3
INT101
0
1
teach@kbtu.kz
tea123
6
s1
INT101
25
25
30
12
1
10
1
Integration research project
0
1
stud@int.test
stu123
6
teach@int.test
5
7
2
1
4
0
1
admin@int.test
adm123
4
0
0
n
INPUT
}

run_phase_a | "${JAVA_RUN[@]}" 2>&1 | tee "$PHASE_A_OUTPUT"

echo "[integration-test] Фаза B — новый процесс JVM, загрузка из data/university-state.ser..."
PHASE_B_OUTPUT="$(mktemp)"
run_phase_b() {
  cat <<'INPUT'
y
1
stud@int.test
stu123
1
4
0
1
teach@int.test
tea123
7
0
4
0
n
INPUT
}

run_phase_b | "${JAVA_RUN[@]}" 2>&1 | tee "$PHASE_B_OUTPUT"

FAIL=0
MERGED="$(mktemp)"
cat "$PHASE_A_OUTPUT" "$PHASE_B_OUTPUT" >"$MERGED"

checks=(
  "INT101"
  "Persistence line from integration test"
  "[OK] Данные загружены"
  "Запись успешна"
  "Оценка сохранена"
  "Integration research project"
)

for needle in "${checks[@]}"; do
  if ! grep -qF "$needle" "$MERGED"; then
    echo "[integration-test] ОШИБКА: в выводе нет строки: $needle"
    FAIL=1
  fi
done

rm -f "$PHASE_A_OUTPUT" "$PHASE_B_OUTPUT" "$MERGED"

if [[ "$FAIL" -ne 0 ]]; then
  echo "[integration-test] ЗАВЕРШЕНО С ОШИБКОЙ"
  exit 1
fi

echo "[integration-test] Все маркеры найдены — консоль и сериализация проходят сценарий."
